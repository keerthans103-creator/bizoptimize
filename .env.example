# Copy this file to .env and fill in your own values before running
# `docker compose up`. Docker Compose automatically reads a .env file
# in the project root.

# Required: your own Gemini API key -- free tier, good for students.
# Get one at https://aistudio.google.com/apikey (sign in with a Google account).
# Used only for parsing workflow text into discrete tasks -- never for
# scoring automatability (that's the Random Forest's job).
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: override the Gemini model used for parsing.
GEMINI_MODEL=gemini-flash-lite-latest

# Optional: override the JWT signing secret for the Spring Boot backend.
# The default is fine for local dev only -- change it before any real deployment.
JWT_SECRET=dev-only-secret-change-me-before-any-real-deployment-0123456789
